# Original screenshots (we ship the optimized .webp instead)
assets/works/**/*.png
assets/works/**/*.jpg
assets/works/**/*.jpeg

# Tetris course: compiled .class dirs are transient artifacts.
# The SDK jar is embedded as base64 inside runtime.js at build time,
# so no step-NN/*.jar is committed either. tools.jar IS committed —
# it's the OpenJDK javac that runs in the browser for the editor.
learn/tetris/**/classes/
learn/tetris/sdk/*.jar
learn/tetris/step-*/*.jar
learn/tetris/**/*.jar.b64
.tmp-*.jar

# Local Lighthouse reports
lighthouse-report*.json

# Cloudflare Worker (explain-worker): wrangler のローカル secret/状態
cloudflare/**/.dev.vars
cloudflare/**/.wrangler/
cloudflare/**/node_modules/

# Java 復習アプリの参考用 PDF (社内資料、コミット禁止)
Javaプログラミング基礎_PDF/
