# Tetris course: compiled .class / .jar are build artifacts (not served as
# static assets — the Pages Function embeds jar bytes as base64). Only
# .java sources and the middleware are committed.
learn/tetris/**/classes/
learn/tetris/**/*.jar
learn/tetris/**/*.jar.b64

# Local Lighthouse reports
lighthouse-report*.json
